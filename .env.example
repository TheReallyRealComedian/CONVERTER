# Environment Variables for File Transformer App
# WARNING: Do not commit this file to git! It contains sensitive API keys.

# Deepgram API Key for audio transcription
DEEPGRAM_API_KEY=<key_here>

# Google Gemini API Key for AI-powered features
GEMINI_API_KEY=<key_here>

# Google Cloud credentials path (for Text-to-Speech)
GOOGLE_APPLICATION_CREDENTIALS=/app/google-credentials.json

# Secret key for Flask sessions (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret

# Shared secret for the server-to-server ingestion endpoint (NL1, see
# docs/ingest_contract.md). UNSET/EMPTY = endpoint is fail-closed (503).
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
INGEST_TOKEN=

# Optional: username that ingested rows are attributed to. If set it must match
# an existing user; if empty the single-user fallback (first user) is used.
# Also used by the card write API (R4-LEARN) to attribute agent-authored cards.
INGEST_USER=

# Shared secret for the card write API (R4-LEARN: POST/PATCH /api/cards, the
# agent's recall-layer writes). Separate from INGEST_TOKEN for independent
# rotation. UNSET/EMPTY = card writes are fail-closed (503).
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
CARD_TOKEN=

# Optional: spaced-repetition scheduling engine (R4-LEARN). Both defaults work
# unset. SCHEDULER_ENGINE = fsrs (default) | sm2 (classic SuperMemo-2 fallback).
# FSRS_DESIRED_RETENTION = target recall as a float in (0,1), default 0.9.
SCHEDULER_ENGINE=fsrs
FSRS_DESIRED_RETENTION=0.9

# Send-to-Kindle (KINDLE, see docs/kindle.md). Mails a library element as an
# EPUB to a Kindle. ANY required key UNSET/EMPTY = the endpoint is fail-closed
# (503), exactly like CARD_TOKEN. The recipient is server-fixed (KINDLE_TO_EMAIL)
# and never taken from a request (anti-relay).
# Amazon one-time setup: put KINDLE_FROM_EMAIL on the "Approved Personal Document
# E-mail List" (Manage Your Content and Devices) and look up your device's
# <name>@kindle.com address there too.
KINDLE_SMTP_HOST=
KINDLE_SMTP_PORT=465
KINDLE_SMTP_USERNAME=
KINDLE_SMTP_PASSWORD=
KINDLE_FROM_EMAIL=
KINDLE_TO_EMAIL=