# Environment Variables for File Transformer App
# WARNING: Do not commit this file to git! It contains sensitive API keys.

# Deepgram API Key for audio transcription
DEEPGRAM_API_KEY=<key_here>

# Google Gemini API Key for AI-powered features
GEMINI_API_KEY=<key_here>

# Google Cloud credentials path (for Text-to-Speech)
GOOGLE_APPLICATION_CREDENTIALS=/app/google-credentials.json

# Secret key for Flask sessions (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret